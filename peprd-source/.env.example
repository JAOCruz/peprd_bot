# ==== Server ====
PORT=8889
NODE_ENV=development

# ==== Business Info ====
BUSINESS_NAME=PepRD
BOT_NAME=Peppi
BUSINESS_TAGLINE=Péptidos de investigación de alta pureza — envíos discretos a toda RD
BUSINESS_ADDRESS=Santo Domingo
BUSINESS_CITY=Santo Domingo
BUSINESS_PHONE=+1 809 870 8700
BUSINESS_EMAIL=ventas@peprd.io
BUSINESS_INSTAGRAM=@peprd
BUSINESS_HOURS=Lun-Vie 9:00am - 6:00pm | Sáb 10:00am - 2:00pm
TIMEZONE=America/Santo_Domingo
CURRENCY=DOP
CURRENCY_SYMBOL=RD$
LANGUAGE=es

# ==== Shipping ====
DELIVERY_ENABLED=true
DELIVERY_MIN_ORDER=1000
DELIVERY_FEE_BASE=250
DELIVERY_ZONES=Santo Domingo,Santiago,Puerto Plata,La Romana,Punta Cana

# ==== Database ====
DB_HOST=localhost
DB_PORT=5432
DB_NAME=peprd_bot
DB_USER=postgres
DB_PASSWORD=__FILL_DB_PASSWORD__

# ==== JWT ====
JWT_SECRET=__FILL_JWT_SECRET__
JWT_EXPIRES_IN=7d

# ==== LLM ====
GEMINI_API_KEY=__FILL_GEMINI_KEY__
MINIMAX_API_KEY=__FILL_MINIMAX_KEY__
LLM_PRIMARY=gemini

# ==== WhatsApp ====
WA_SESSION_DIR=./wa_sessions
UPLOADS_DIR=./public/uploads
# Set to true to skip WhatsApp startup (use /api/chat web tester only)
DISABLE_WA=false

# ==== URLs ====
API_BASE_URL=http://localhost:8889
